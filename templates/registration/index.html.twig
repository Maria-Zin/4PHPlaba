{% extends 'base.html.twig' %}

{% block title %}Регистрация{% endblock %}

{% block body %}
<div class="container auth-page">
    <div class="auth-card">
        <h1 class="auth-card__title">Регистрация</h1>
        <p class="auth-card__lead">Создайте аккаунт, указав email и пароль.</p>

        <form method="post" action="{{ path('app_registration') }}" class="auth-form">
            <div class="auth-field">
                <label for="_email">Электронная почта</label>
                <input id="_email" name="_email" type="email" required autocomplete="email" />
            </div>
            <div class="auth-field">
                <label for="_password">Пароль</label>
                <input id="_password" name="_password" type="password" required autocomplete="new-password" />
            </div>
            <div class="auth-actions">
                <input type="submit" value="Зарегистрироваться" />
            </div>
        </form>

        <div class="auth-links">
            <a href="{{ path('app_login') }}">Уже есть аккаунт? Войти</a>
        </div>
    </div>
</div>
{% endblock %}
